DirectoryIndex disabled
RewriteEngine On

# Redirigir todas las solicitudes al puerto interno 3000 de Node.js
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

# Forzar redirección HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Evitar el acceso a archivos de configuración del proyecto
<FilesMatch "\.(env|git|json|lock)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Compresión GZIP de transferencia
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
